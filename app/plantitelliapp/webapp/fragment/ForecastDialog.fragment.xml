<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        title="AI Forecast"
        contentWidth="24rem"
        class="sapUiContentPadding">
        <content>
            <VBox class="sapUiSmallMarginBottom">
                <ObjectStatus
                    text="Model: {forecast>/model}"
                    class="sapUiTinyMarginBottom" />

                <Text
                    text="{= 'Predicted stock level: ' + ${forecast>/prediction} }"
                    visible="{= ${forecast>/type} === 'stock'}"
                    class="sapUiSmallMarginTop" />

                <Text
                    text="{= 'Predicted delivery delay: ' + ${forecast>/prediction_delay_days} + ' day(s)' }"
                    visible="{= ${forecast>/type} === 'delivery'}"
                    class="sapUiSmallMarginTop" />

                <ObjectStatus
                    text="{forecast>/risk_status}"
                    state="{= ${forecast>/risk_status} === 'High' ? 'Error' : (${forecast>/risk_status} === 'Medium' ? 'Warning' : 'Success')}"
                    visible="{= ${forecast>/type} === 'delivery'}"
                    class="sapUiSmallMarginTop" />
            </VBox>
        </content>
        <beginButton>
            <Button
                text="Close"
                press=".onForecastDialogClose" />
        </beginButton>
    </Dialog>
</core:FragmentDefinition>