<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        title="Delivery Forecast"
        contentWidth="24rem"
        class="sapUiContentPadding">

        <content>
            <VBox class="sapUiMediumMargin">

                <!-- Big Number -->
                <ObjectNumber
                    number="{forecast>/prediction_delay_days}"
                    unit="Days"
                    emphasized="true"
                    state="{forecast>/statusState}" />

                <!-- Label -->
                <Text
                    text="Predicted Delivery Delay"
                    class="sapUiSmallMarginBottom"/>

                <!-- Status -->
                <ObjectStatus
                    text="{forecast>/statusText}"
                    state="{forecast>/statusState}"
                    class="sapUiSmallMarginTop"/>

                <!-- Message -->
                <MessageStrip
                    text="{forecast>/messageText}"
                    type="{forecast>/messageType}"
                    showIcon="true"
                    class="sapUiMediumMarginTop"/>

            </VBox>
        </content>

        <beginButton>
            <Button
                text="Close"
                press="onForecastDialogClose"/>
        </beginButton>

    </Dialog>
</core:FragmentDefinition>