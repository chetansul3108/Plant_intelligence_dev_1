<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        title="Delivery Forecast"
        contentWidth="24rem"
        class="sapUiContentPadding">

        <content>
            <VBox class="sapUiMediumMargin">

                <!-- Big Number -->
                <ObjectNumber
                    number="{forecast>/prediction_delay_days}"
                    unit="Days"
                    emphasized="true"
                    state="Error"/>

                <!-- Label -->
                <Text
                    text="Predicted Delivery Delay"
                    class="sapUiSmallMarginBottom"/>

                <!-- Risk -->
                <ObjectStatus
                    text="{forecast>/risk_status}"
                    state="Error"
                    class="sapUiSmallMarginTop"/>

                <!-- Message -->
                <MessageStrip
                    text="High delay expected. Take action."
                    type="Error"
                    showIcon="true"
                    class="sapUiMediumMarginTop"/>

            </VBox>
        </content>

        <beginButton>
            <Button
                text="Close"
                press="onForecastDialogClose"/>
        </beginButton>

    </Dialog>
</core:FragmentDefinition>