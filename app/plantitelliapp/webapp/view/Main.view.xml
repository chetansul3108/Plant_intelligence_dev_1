<mvc:View
    controllerName="plant_intelligence_dev.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true">
 
    <App>
        <Page title="" class="kpiPage">
            <customHeader>
                <Toolbar class="dashboardHeader" height="3.5rem">
                    <Image
                        src="images/yash-logo.png"
                        height="1.9rem"
                        class="headerLogoImg" />
 
                    <Title
                        text="AI-Powered Plant and Supply Chain Intelligence"
                        level="H3"
                        class="titleMain" />
 
                    <ToolbarSpacer />
                </Toolbar>
            </customHeader>
 
            <content>
                <HBox
                    justifyContent="SpaceBetween"
                    alignItems="End"
                    class="sectionHeaderRow">
                    <VBox>
                        <Title
                            text="KPI Overview"
                            level="H4"
                            class="sectionTitle" />
                        <Text
                            text="Real-time performance across all plants"
                            class="sectionSubtitle" />
                    </VBox>
                    <Text
                        text="Updated 2 min ago"
                        class="sectionUpdated" />
                </HBox>
 
                <HBox
                    justifyContent="SpaceBetween"
                    class="dashboardMainRow"
                    width="100%">
 
                    <VBox
                        class="kpiColumn"
                        fitContainer="true">
 
                        <l:Grid
                            defaultSpan="XL6 L6 M6 S12"
                            vSpacing="0"
                            hSpacing="0"
                            class="kpiGrid {dashboardModel>/hasSelectionClass}"
                            content="{dashboardModel>/cards}">
 
                            <VBox class="kpiCardWrapper">
                                <customData>
                                    <core:CustomData
                                        key="cardkey"
                                        value="{dashboardModel>key}" />
                                    <core:CustomData
                                        key="selected"
                                        value="{dashboardModel>isSelected}"
                                        writeToDom="true" />
                                </customData>
 
                                <layoutData>
                                    <l:GridData
                                        span="XL6 L6 M6 S12"
                                        linebreak="{dashboardModel>lineBreak}" />
                                </layoutData>
 
                                <Panel class="kpiTile {dashboardModel>accentClass}">
                                    <content>
                                        <VBox class="kpiTileInner">
                                            <HBox
                                                justifyContent="SpaceBetween"
                                                alignItems="Start"
                                                class="kpiTopRow">
                                                <VBox class="kpiIconBox {dashboardModel>iconClass}" />
 
                                                <ObjectStatus
                                                    text="{dashboardModel>statusText}"
                                                    state="{dashboardModel>statusState}"
                                                    inverted="true"
                                                    class="kpiStatusBadge" />
                                            </HBox>
 
                                            <VBox class="kpiBodyBlock">
                                                <Text
                                                    text="{dashboardModel>title}"
                                                    class="kpiTitle" />
 
                                                <HBox
                                                    alignItems="End"
                                                    class="kpiValueRow">
                                                    <Text
                                                        text="{dashboardModel>value}"
                                                        class="kpiValue" />
                                                    <Text
                                                        text="{dashboardModel>unit}"
                                                        class="kpiUnit" />
                                                </HBox>
 
                                                <Text
                                                    text="{dashboardModel>delta}"
                                                    class="kpiDeltaText {dashboardModel>deltaClass}" />
                                            </VBox>
 
                                            <HBox
                                                justifyContent="SpaceBetween"
                                                class="kpiFooterRow">
                                                <Text
                                                    text="{dashboardModel>footerLeft}"
                                                    class="kpiFooterLeft" />
                                                <Text
                                                    text="{dashboardModel>footerRight}"
                                                    class="kpiFooterRight" />
                                            </HBox>

                                            <HBox
                                                justifyContent="End"
                                                class="kpiForecastRow sapUiTinyMarginTop">
                                                <Button
                                                    text="Forecast"
                                                    icon="sap-icon://line-chart"
                                                    type="Transparent"
                                                    class="forecastTrigger"
                                                    
                                                    press=".onForecastPress">
                                                    <customData>
                                                        <core:CustomData
                                                            key="cardKey"
                                                            value="{dashboardModel>key}" />
                                                    </customData>
                                                </Button>
                                            </HBox>
                                        </VBox>
                                    </content>
                                </Panel>
                            </VBox>
                        </l:Grid>
                    </VBox>
 
                    <VBox
                        class="aiSummaryColumn"
                        fitContainer="true">
 
                        <Panel class="aiSummaryPanel">
                            <content>
                                <VBox class="aiSummaryInner">
                                    <HBox
                                        alignItems="Center"
                                        class="aiSummaryHeader">
                                        <core:Icon
                                            src="sap-icon://ai"
                                            size="1.5rem"
                                            class="aiSummaryIcon" />
                                        <Title
                                            text="AI Summary"
                                            level="H6"
                                            class="aiSummaryTitle" />
                                    </HBox>
 
                                    <Text
                                        text="{dashboardModel>/selectedInsight/subtitle}"
                                        class="aiSummarySubtitle"/>
 
                                    <VBox
                                        class="aiInsightItem"
                                        visible="{dashboardModel>/showInsight}">
                                        <HBox
                                            alignItems="Center"
                                            class="aiInsightHeader">
                                            <core:Icon
                                                src="{dashboardModel>/selectedInsight/icon}"
                                                class="aiInsightIcon {dashboardModel>/selectedInsight/iconClass}" />
                                            <Text
                                                text="{dashboardModel>/selectedInsight/title}"
                                                class="aiInsightTitle" />
                                        </HBox>
 
                                        <Text
                                            text="{dashboardModel>/selectedInsight/text}"
                                            class="aiInsightText" />
 
                                        <VBox class="aiRecommendBlock">
                                            <Text
                                                text="RECOMMENDED ACTION"
                                                class="aiRecommendLabel" />
                                            <Text
                                                text="{dashboardModel>/selectedInsight/recommendation}"
                                                class="aiRecommendText" />
                                        </VBox>
                                    </VBox>
 
                                    <VBox
                                        class="aiEmptyState"
                                        visible="{dashboardModel>/showEmpty}">
                                        <core:Icon
                                            src="sap-icon://ai"
                                            size="2rem"
                                            class="aiEmptyIcon" />
                                        <Text
                                            text="Please select a card to see AI summary"
                                            class="aiEmptyText" />
                                    </VBox>
                                </VBox>
                            </content>
                        </Panel>
                    </VBox>
                </HBox>
            </content>
        </Page>
    </App>
</mvc:View>