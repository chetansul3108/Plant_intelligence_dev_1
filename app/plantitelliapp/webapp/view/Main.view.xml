<mvc:View
    controllerName="plant_intelligence_dev.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <App>
        <Page title="Plant Intelligence Dashboard" class="kpiPage">
            <content>
                <l:Grid
                    defaultSpan="XL4 L4 M6 S12"
                    vSpacing="1"
                    hSpacing="1"
                    class="kpiGrid"
                    content="{dashboardModel>/cards}">

                    <Panel class="kpiTile {dashboardModel>accentClass}">
                        <content>
                            <VBox class="kpiTileInner">
                                <HBox justifyContent="SpaceBetween" alignItems="Start" class="kpiTopRow">
                                    <VBox class="kpiIconBox {dashboardModel>iconClass}" />

                                    <ObjectStatus
                                        text="{dashboardModel>statusText}"
                                        state="{dashboardModel>statusState}"
                                        inverted="true"
                                        class="kpiStatusBadge" />
                                </HBox>

                                <VBox class="kpiBodyBlock">
                                    <Text text="{dashboardModel>title}" class="kpiTitle" />

                                    <HBox alignItems="End" class="kpiValueRow">
                                        <Text text="{dashboardModel>value}" class="kpiValue" />
                                        <Text text="{dashboardModel>unit}" class="kpiUnit" />
                                    </HBox>

                                    <Text
                                        text="{dashboardModel>delta}"
                                        class="kpiDeltaText {dashboardModel>deltaClass}" />
                                </VBox>

                                <VBox class="kpiChartArea {dashboardModel>chartClass}" />

                                <HBox justifyContent="SpaceBetween" class="kpiFooterRow">
                                    <Text text="{dashboardModel>footerLeft}" class="kpiFooterLeft" />
                                    <Text text="{dashboardModel>footerRight}" class="kpiFooterRight" />
                                </HBox>

                                <HBox justifyContent="End" class="kpiActionRow">
    <Button
        text="Load Data"
        type="Transparent"
        press=".onCardPress"
        class="kpiActionButton">
        <customData>
            <core:CustomData key="cardKey" value="{dashboardModel>key}" />
        </customData>
    </Button>
</HBox>
                            </VBox>
                        </content>
                    </Panel>
                </l:Grid>
            </content>
        </Page>
    </App>
</mvc:View>