<mvc:View
    controllerName="plant_intelligence_dev.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <App>
        <Page title="" class="kpiPage">
            <customHeader>

                <Toolbar class="dashboardHeader" height="3.5rem">

                    <core:Icon
                        src="sap-icon://product"
                        size="1.25rem"
                        class="headerLogo"/>

                    <Title
                        text="Plant Intelligence"
                        level="H3"
                        class="titleMain"/>

                    <ToolbarSpacer/>

                    <Button
                        text="AI Copilot"
                        icon="sap-icon://ai"
                        type="Emphasized"
                        class="aiCopilotButton"/>

                    <Avatar
                        displaySize="XS"
                        class="profileAvatarBlank"/>

                    <Avatar
                        displaySize="XS"
                        initials="SC"
                        class="profileAvatarInitials"/>

                </Toolbar>

            </customHeader>
            <content>

                <HBox justifyContent="SpaceBetween" alignItems="End" class="sectionHeaderRow">
                    <VBox>
                        <Title text="KPI Overview" level="H4" class="sectionTitle"/>
                        <Text text="Real-time performance across all plants" class="sectionSubtitle"/>
                    </VBox>
                    <Text text="Updated 2 min ago" class="sectionUpdated"/>
                </HBox>
                <l:Grid
                    defaultSpan="XL4 L4 M6 S12"
                    vSpacing="1"
                    hSpacing="1"
                    class="kpiGrid"
                    content="{dashboardModel>/cards}">

                    <Panel class="kpiTile {dashboardModel>accentClass}">
                        <content>
                            <VBox class="kpiTileInner">
                                <HBox justifyContent="SpaceBetween" alignItems="Start" class="kpiTopRow">
                                    <VBox class="kpiIconBox {dashboardModel>iconClass}" />

                                    <ObjectStatus
                                        text="{dashboardModel>statusText}"
                                        state="{dashboardModel>statusState}"
                                        inverted="true"
                                        class="kpiStatusBadge" />
                                </HBox>

                                <VBox class="kpiBodyBlock">
                                    <Text text="{dashboardModel>title}" class="kpiTitle" />

                                    <HBox alignItems="End" class="kpiValueRow">
                                        <Text text="{dashboardModel>value}" class="kpiValue" />
                                        <Text text="{dashboardModel>unit}" class="kpiUnit" />
                                    </HBox>

                                    <Text
                                        text="{dashboardModel>delta}"
                                        class="kpiDeltaText {dashboardModel>deltaClass}" />
                                </VBox>

                                <HBox justifyContent="SpaceBetween" class="kpiFooterRow">
                                    <Text text="{dashboardModel>footerLeft}" class="kpiFooterLeft" />
                                    <Text text="{dashboardModel>footerRight}" class="kpiFooterRight" />
                                </HBox>
                            </VBox>
                        </content>
                    </Panel>
                </l:Grid>

            </content>
        </Page>
    </App>
</mvc:View>